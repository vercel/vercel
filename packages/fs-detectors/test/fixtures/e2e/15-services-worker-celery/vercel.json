{
  "projectSettings": {
    "framework": "services"
  },
  "experimentalServices": {
    "web": {
      "framework": "flask",
      "entrypoint": "app.py",
      "routePrefix": "/"
    },
    "worker": {
      "type": "worker",
      "entrypoint": "worker/run.py",
      "topics": ["jobs"]
    }
  },
  "build": {
    "env": {
      "VERCEL_CLI_VERSION": "vercel@https://vercel-7nsizoodj.vercel.sh/tarballs/vercel.tgz"
    }
  }
}
