      "routePrefix": "/api/py"
    },
    "node-api": {
      "entrypoint": "services/node-api/index.js",
      "routePrefix": "/api/node"
    },
    "express-api": {
      "entrypoint": "services/express-api/index.js",
      "routePrefix": "/api/express"
    },
    "koa-api": {
      "entrypoint": "services/koa-api/index.js",
      "routePrefix": "/api/koa"
    },
    "hono-api": {
      "entrypoint": "services/hono-api/index.js",
      "routePrefix": "/api/hono"
