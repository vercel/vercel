{
  "probes": [
    {
      "path": "/",
      "status": 200,
      "mustContain": "Hello from Flask web service (multiple topics)"
    },
    {
      "path": "/health",
      "status": 200,
      "mustContain": "ok"
    },
    {
      "path": "/enqueue",
      "method": "POST",
      "body": { "request_id": "probe-17" },
      "status": 200,
      "mustContain": "probe-17"
    },
    {
      "path": "/status/orders/probe-17",
      "status": 200,
      "mustContain": "probe-17",
      "retries": 5,
      "retryDelay": 2000
    },
    {
      "path": "/status/events/probe-17",
      "status": 200,
      "mustContain": "probe-17",
      "retries": 5,
      "retryDelay": 2000
    },
    {
      "path": "/_svc/worker/index",
      "method": "POST",
      "body": {},
      "status": 404,
      "mustContain": "404 from Flask web service"
    },
    {
      "path": "/does-not-exist",
      "status": 404,
      "mustContain": "404 from Flask web service"
    }
  ]
}
