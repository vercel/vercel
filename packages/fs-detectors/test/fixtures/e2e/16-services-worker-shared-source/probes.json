{
  "probes": [
    {
      "path": "/",
      "status": 200,
      "mustContain": "Hello from Flask web service"
    },
    {
      "path": "/health",
      "status": 200,
      "mustContain": "ok"
    },
    {
      "path": "/enqueue/email",
      "method": "POST",
      "body": { "request_id": "probe-16-emails" },
      "status": 200,
      "mustContain": "probe-16-emails"
    },
    {
      "path": "/status/emails/probe-16-emails",
      "status": 200,
      "mustContain": "probe-16-emails",
      "retries": 5,
      "retryDelay": 2000
    },
    {
      "path": "/enqueue/report",
      "method": "POST",
      "body": { "request_id": "probe-16-reports" },
      "status": 200,
      "mustContain": "probe-16-reports"
    },
    {
      "path": "/status/reports/probe-16-reports",
      "status": 200,
      "mustContain": "probe-16-reports",
      "retries": 5,
      "retryDelay": 2000
    },
    {
      "path": "/_svc/worker-emails/index",
      "method": "POST",
      "body": {},
      "status": 404,
      "mustContain": "404 from Flask web service"
    },
    {
      "path": "/_svc/worker-reports/index",
      "method": "POST",
      "body": {},
      "status": 404,
      "mustContain": "404 from Flask web service"
    },
    {
      "path": "/does-not-exist",
      "status": 404,
      "mustContain": "404 from Flask web service"
    }
  ]
}
