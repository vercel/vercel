{
  "uploadNowJson": true,
  "projectSettings": {
    "framework": "services"
  },
  "experimentalServices": {
    "web": {
      "framework": "flask",
      "entrypoint": "app.py",
      "routePrefix": "/"
    },
    "worker-emails": {
      "type": "worker",
      "entrypoint": "worker/run.py",
      "topics": ["emails"]
    },
    "worker-reports": {
      "type": "worker",
      "entrypoint": "worker/run.py",
      "topics": ["reports"]
    }
  }
}
