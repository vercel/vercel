{
  "probes": [
    {
      "path": "/",
      "status": 200,
      "mustContain": "Hello from Flask web service (wildcard topic)"
    },
    {
      "path": "/health",
      "status": 200,
      "mustContain": "ok"
    },
    {
      "path": "/enqueue",
      "method": "POST",
      "body": { "request_id": "probe-14-job-events" },
      "status": 200,
      "mustContain": "probe-14-job-events"
    },
    {
      "path": "/status/job-events/probe-14-job-events",
      "status": 200,
      "mustContain": "probe-14-job-events",
      "retries": 5,
      "retryDelay": 2000
    },
    {
      "path": "/_svc/worker/index",
      "method": "POST",
      "body": {},
      "status": 404,
      "mustContain": "404 from Flask web service"
    },
    {
      "path": "/does-not-exist",
      "status": 404,
      "mustContain": "404 from Flask web service"
    }
  ]
}
