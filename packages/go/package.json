    "@types/yauzl-promise": "2.1.0",
    "@vercel/build-utils": "workspace:*",
    "async-retry": "1.3.3",
    "execa": "^1.0.0",
    "fs-extra": "^7.0.0",
    "node-fetch": "^2.2.1",
    "string-argv": "0.3.1",
    "tar": "7.5.11",
    "vitest": "2.0.3",
    "xdg-app-paths": "5.1.0",
    "yauzl-promise": "2.1.3"
  }
