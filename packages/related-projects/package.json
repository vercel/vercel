{
  "name": "@vercel/related-projects",
  "version": "1.1.0",
  "description": "Vercel utilities for working with related projects",
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/vercel/vercel.git",
    "directory": "packages/related-projects"
  },
  "license": "Apache-2.0",
  "scripts": {
    "build": "node ../../utils/build.mjs",
    "test": "vitest run --config ../../vitest.config.mts --coverage",
    "test-unit": "pnpm test",
    "type-check": "tsc --noEmit",
    "vitest-run": "vitest -c ../../vitest.config.mts",
    "vitest-unit": "glob --absolute 'test/**/*.test.js' 'test/**/*.test.ts' 'test/**/*.test.mjs' 'test/**/*.test.mts' 'tests/**/*.test.js' 'tests/**/*.test.ts'"
  },
  "devDependencies": {
    "@types/node": "20.11.0",
    "@vitest/coverage-v8": "2.0.3",
    "ajv": "^6.12.3",
    "vitest": "2.0.3"
  },
  "optionalDependencies": {
    "ajv": "^6.12.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
