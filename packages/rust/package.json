    "@vercel/build-utils": "workspace:*",
    "@vercel/routing-utils": "workspace:*",
    "@vercel/style-guide": "^4.0.2",
    "eslint": "^8.35.0",
    "husky": "^8.0.3",
    "ms": "^2.1.3",
    "prettier": "^2.8.4",
    "rimraf": "^4.1.1",
    "vitest": "2.0.3"
  }
