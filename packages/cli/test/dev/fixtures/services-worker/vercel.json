{
  "experimentalServices": {
    "web": {
      "framework": "fastapi",
      "entrypoint": "web",
      "routePrefix": "/"
    },
    "worker-exact": {
      "type": "worker",
      "runtime": "python",
      "entrypoint": "worker/worker.py",
      "topic": "tasks-topic"
    },
    "worker-wildcard": {
      "type": "worker",
      "runtime": "python",
      "entrypoint": "worker-wildcard/worker.py",
      "topic": "tasks-*"
    }
  }
}
