{
  "env": {
    "ECHO_VAR": {"type": "service-ref", "service": "service-a"},
    "GLOBAL_REF": {"type": "service-ref", "service": "service-b"}
  },
  "experimentalServices": {
    "service-next": {
      "framework": "vite",
      "entrypoint": "apps/web",
      "mount": "/",
      "env": {
        "VITE_SERVICE_A_URL": {"type": "service-ref", "service": "service-a"},
        "VITE_SERVICE_B_URL": {"type": "service-ref", "service": "service-b"}
      }
    },
    "service-a": {
      "framework": "fastapi",
      "entrypoint": "services/service-a",
      "mount": "/api/a",
      "env": {
        "SERVICE_B_URL": {"type": "service-ref", "service": "service-b"},
        "ECHO_VAR": {"type": "service-ref", "service": "service-b"}
      }
    },
    "service-b": {
      "framework": "fastapi",
      "entrypoint": "services/service-b",
      "mount": "/api/b"
    }
  }
}
