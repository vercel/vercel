{
  "probes": [
    {
      "path": "/",
      "status": 200,
      "bodyMustBe": "Hello World",
      "responseHeaders": {
        "content-type": "/text\\/plain/"
      }
    },
    {
      "path": "/health",
      "status": 200,
      "bodyMustBe": "ok"
    },
    {
      "path": "/user/vercel%20team",
      "status": 200,
      "bodyMustBe": "User ID: vercel team"
    },
    {
      "path": "/does-not-exist",
      "status": 404,
      "bodyMustBe": "Custom 404: /does-not-exist"
    }
  ]
}
